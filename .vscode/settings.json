{
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.next/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/out/**": true,
    "**/.cache/**": true,
    "**/.pnpm-store/**": true,
    "**/.turbo/**": true,
    "**/.vercel/**": true,
    "**/coverage/**": true,
    "**/.nyc_output/**": true,
    "**/test-screenshots/**": true,
    "**/playwright-report/**": true,
    "**/test-results/**": true,
    "**/.git/**": true
  },
  "files.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/dist": true,
    "**/build": true,
    "**/out": true,
    "**/.cache": true,
    "**/.pnpm-store": true,
    "**/.turbo": true,
    "**/.vercel": true,
    "**/coverage": true,
    "**/.nyc_output": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/dist": true,
    "**/build": true,
    "**/out": true,
    "**/.cache": true,
    "**/.pnpm-store": true,
    "**/.turbo": true,
    "**/.vercel": true,
    "**/coverage": true,
    "**/.nyc_output": true,
    "**/test-screenshots": true,
    "**/playwright-report": true,
    "**/test-results": true,
    "**/.git": true
  },
  "search.useIgnoreFiles": true,
  "search.followSymlinks": false,
  "search.maxResults": 8000,
  "git.autorefresh": false,
  "typescript.tsserver.maxTsServerMemory": 2048,
  "editor.minimap.enabled": false,
  "explorer.autoReveal": false,
  "extensions.autoUpdate": false
}
