# Solo para DESARROLLO LOCAL. En producción app-test y chat-test no llevan puerto.
# Copia a .env.development.local para usar en local con dominios y puertos.
# Así el iframe del Copilot y los redirects usan las mismas URLs que el navegador.
#
# Requiere /etc/hosts:
#   127.0.0.1   app-test.bodasdehoy.com
#   127.0.0.1   chat-test.bodasdehoy.com
#
# Levantar con: pnpm dev:local (desde la raíz) o pnpm run dev:local (desde apps/web)

NEXT_PUBLIC_DIRECTORY=http://app-test.bodasdehoy.com:8080
NEXT_PUBLIC_EVENTSAPP=http://app-test.bodasdehoy.com:8080
NEXT_PUBLIC_CHAT=http://chat-test.bodasdehoy.com:3210

# ─── WHITELABEL EN DESARROLLO ────────────────────────────────────────────────
# Fuerza un whitelabel concreto. Prioridad absoluta sobre la detección por hostname.
# Funciona en CUALQUIER entorno no-producción: localhost, chat-test.*, app-test.*,
# ch1.bodasdehoy.com, dev-pedro.vivetuboda.com, cualquier subdominio asignado.
#
# Valores válidos: bodasdehoy | eventosplanificador | eventosorganizador |
#                  vivetuboda | champagne-events | annloevents |
#                  miamorcitocorazon | eventosintegrados | ohmaratilano |
#                  corporativozr | theweddingplanner
#
# Si no se define, se detecta automáticamente por hostname.
# NUNCA definir esta variable en Vercel producción.
#
# NEXT_PUBLIC_DEV_WHITELABEL=vivetuboda

# ─── GraphQL / sockets (host actual: api2.eventosorganizador.com) ───
# En Vercel (rama test, preview, production) copiar estos valores si aún apuntan al host antiguo:
#   NEXT_PUBLIC_BASE_API_BODAS=https://api2.eventosorganizador.com
#   NEXT_PUBLIC_API_BODAS_URL=https://api2.eventosorganizador.com/graphql
#   API_BODAS_URL=https://api2.eventosorganizador.com   # para proxy /api/proxy-bodas
#   API_BODAS_URL_FALLBACK=https://api2.eventosorganizador.com
#   NEXT_PUBLIC_API_BODAS_URL_FALLBACK=https://api2.eventosorganizador.com/graphql
# ApiApp (imágenes, queries evento) sigue en apiapp:
#   NEXT_PUBLIC_BASE_URL=https://apiapp.bodasdehoy.com
#
# DNS en dev: scripts/dns-dev-preflight.cjs (solo al arrancar `pnpm dev`). DNS_OVERRIDE_DISABLED=1 para apagar.
# DNS_SERVERS=8.8.8.8,1.1.1.1
