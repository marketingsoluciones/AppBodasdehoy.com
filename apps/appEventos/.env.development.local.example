# Solo para DESARROLLO. En túnel (app-dev / chat-dev) no hace falta puerto.
# Copia a .env.development.local para que el iframe del Copilot y los redirects
# usen las mismas URLs que el navegador.
#
# Requiere /etc/hosts si quieres usar sin túnel:
#   127.0.0.1   app-dev.bodasdehoy.com
#   127.0.0.1   chat-dev.bodasdehoy.com
#
# Levantar con: pnpm dev (desde la raíz) y ./scripts/iniciar-tunnel.sh

NEXT_PUBLIC_DIRECTORY=https://app-dev.bodasdehoy.com
NEXT_PUBLIC_EVENTSAPP=https://app-dev.bodasdehoy.com
NEXT_PUBLIC_CHAT=https://chat-dev.bodasdehoy.com

# ─── WHITELABEL EN DESARROLLO ────────────────────────────────────────────────
# Fuerza un whitelabel concreto. Prioridad absoluta sobre la detección por hostname.
# Funciona en CUALQUIER entorno no-producción: localhost, chat-test.*, app-test.*,
# ch1.bodasdehoy.com, dev-pedro.vivetuboda.com, cualquier subdominio asignado.
#
# Valores válidos: bodasdehoy | eventosplanificador | eventosorganizador |
#                  vivetuboda | champagne-events | annloevents |
#                  miamorcitocorazon | eventosintegrados | ohmaratilano |
#                  corporativozr | theweddingplanner
#
# Si no se define, se detecta automáticamente por hostname.
# NUNCA definir esta variable en Vercel producción.
#
# NEXT_PUBLIC_DEV_WHITELABEL=vivetuboda

# ─── API MCP GraphQL (antes API2) ───────────────────────────────────────────
# Mejor práctica: usar nombres canónicos (el número de versión cambia, el nombre no).
#   NEXT_PUBLIC_API_MCP_GRAPHQL_URL=https://api3-mcp-graphql.eventosorganizador.com/graphql
#   API_MCP_GRAPHQL_URL=https://api3-mcp-graphql.eventosorganizador.com/graphql
#
# Aliases legacy (solo si algún entorno antiguo los necesita):
#   NEXT_PUBLIC_API_BODAS_URL=https://api3-mcp-graphql.eventosorganizador.com/graphql
#   API_BODAS_URL=https://api3-mcp-graphql.eventosorganizador.com
#
# Fallback antiguos (evitar si no hace falta):
#   NEXT_PUBLIC_BASE_API_BODAS=https://api2.eventosorganizador.com
#   NEXT_PUBLIC_API_BODAS_URL=https://api2.eventosorganizador.com/graphql
#   API_BODAS_URL=https://api2.eventosorganizador.com
# ApiApp (imágenes, queries evento) sigue en apiapp:
#   NEXT_PUBLIC_IMAGES_BASE_URL=https://apiapp.bodasdehoy.com
#   (Legacy) NEXT_PUBLIC_BASE_URL=https://apiapp.bodasdehoy.com
#
# DNS en dev: scripts/dns-dev-preflight.cjs (solo al arrancar `pnpm dev`). DNS_OVERRIDE_DISABLED=1 para apagar.
# DNS_SERVERS=8.8.8.8,1.1.1.1
