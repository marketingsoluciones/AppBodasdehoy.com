# ========================================
# FRONTEND - Configuración de Producción
# ========================================
# Copiar a .env.local en el servidor de producción

# ========================================
# URL de la aplicación
# ========================================
APP_URL=https://chat.bodasdehoy.com
NEXT_PUBLIC_BASE_PATH=

# ========================================
# BACKEND URL - Conexión al backend separado
# ========================================
# NEXT_PUBLIC_BACKEND_URL: URL pública del backend (llamadas desde navegador)
# BACKEND_INTERNAL_URL: URL para proxy interno de Next.js (server-side)

# Si el backend está en el mismo servidor:
# NEXT_PUBLIC_BACKEND_URL=http://localhost:8030
# BACKEND_INTERNAL_URL=http://localhost:8030

# Si el backend está en servidor separado:
NEXT_PUBLIC_API_IA_URL=https://api3-ia.eventosorganizador.com
API_IA_URL=https://api3-ia.eventosorganizador.com

# Alias legacy (compatibilidad)
NEXT_PUBLIC_BACKEND_URL=https://api3-ia.eventosorganizador.com
PYTHON_BACKEND_URL=https://api3-ia.eventosorganizador.com
USE_PYTHON_BACKEND=true

# ========================================
# GraphQL MCP
# ========================================

# API MCP GraphQL (antes API2)
NEXT_PUBLIC_API_MCP_GRAPHQL_URL=https://api3-mcp-graphql.eventosorganizador.com/graphql
API_MCP_GRAPHQL_URL=https://api3-mcp-graphql.eventosorganizador.com/graphql

# Alias legacy (compatibilidad)
# (Legacy) API2_GRAPHQL_URL=...  (evitar en entornos nuevos)

# ========================================
# Base de datos (Neon PostgreSQL)
# ========================================
NEXT_PUBLIC_SERVICE_MODE=server
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
DATABASE_DRIVER=neon

# ========================================
# Seguridad
# ========================================
KEY_VAULTS_SECRET=tu_secret_generado_con_openssl

# ========================================
# Firebase Auth
# ========================================
NEXT_PUBLIC_FIREBASE_API_KEY=tu_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tu_proyecto
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=tu_proyecto.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# ========================================
# Google OAuth
# ========================================
NEXT_PUBLIC_GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=tu_client_secret

# ========================================
# Storage (Cloudflare R2) — via whitelabel
# ========================================
# Las credenciales R2 (bucket, access key, secret) se obtienen de API MCP
# automáticamente vía getWhiteLabelStorageConfig. NO se configuran aquí.
#
# El frontend pasa X-Development en cada upload y api-ia busca las creds
# en MongoDB (MCP → whitelabel.externalServices[cloudflare_r2]).
#
# Para que el servidor Next.js pueda hacer operaciones S3 internas (KB/RAG),
# necesita autenticarse con MCP usando la support key del development:
SUPPORT_KEY_BODASDEHOY=tu_support_key_aqui
# SUPPORT_KEY_CHAMPAGNEEVENTS=tu_support_key_aqui
# SUPPORT_KEY_EVENTOSORGANIZADOR=tu_support_key_aqui
#
# Formato de la variable: SUPPORT_KEY_{DEVELOPMENT_UPPERCASE}
# El valor lo gestiona el equipo de MCP.
#
# Variables S3_* eliminadas — credenciales vienen de MCP whitelabel.
# S3_ACCESS_KEY_ID    → obsoleta
# S3_SECRET_ACCESS_KEY → obsoleta
# S3_BUCKET           → obsoleta
# S3_ENDPOINT         → obsoleta
# S3_REGION           → obsoleta
# S3_ENABLE_PATH_STYLE → obsoleta
# NEXT_PUBLIC_USE_STORAGE_R2 → obsoleta (R2 siempre activo)
