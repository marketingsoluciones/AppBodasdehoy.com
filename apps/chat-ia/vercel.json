{
  "buildCommand": "pnpm run build:vercel",
  "framework": "nextjs",
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "ignoreCommand": "if [ \"$VERCEL_GIT_COMMIT_REF\" != \"master\" ] && [ \"$VERCEL_GIT_COMMIT_REF\" != \"masterv1\" ] && [ \"$VERCEL_GIT_COMMIT_REF\" != \"dev\" ] && [ \"$VERCEL_GIT_COMMIT_REF\" != \"test\" ]; then exit 0; fi; exit 1",
  "installCommand": "npm i -g pnpm@8.15.9 && pnpm install",
  "regions": ["iad1"],
  "version": 2
}
