# Copia este archivo a .env y rellena solo en tu máquina.
# Nunca subas .env a git (está en .gitignore).

# Slack - nuestro único canal de comunicación: #copilot-api-ia
# Bot Token (lectura de mensajes, ej. slack-read.sh)
SLACK_BOT_TOKEN=
# Webhook para enviar mensajes a #copilot-api-ia (Frontend ↔ api-ia). No nos comunicamos con otros canales.
SLACK_WEBHOOK_FRONTEND=
# ID del canal #copilot-api-ia (para slack-read.sh)
SLACK_CHANNEL_FRONTEND=C0AEV0GCLM7
# Opcional
# SLACK_USER_OAUTH_TOKEN=
# SLACK_VERIFICATION_TOKEN=

# Google Chat (opcional): si lo defines, los avisos del repo van solo a Google Chat en lugar de Slack.
# Ver docs/COMO-CONECTAR-SLACK-COPILOT.md sección 6.
# GOOGLE_CHAT_WEBHOOK_URL=   # URL del webhook de entrada del espacio en Google Chat

# Cloudflare - solo lectura (revisar DNS app-test/chat-test)
# Ver docs/CLOUDFLARE-REVISAR-PARAMETROS-SOLO-LECTURA.md
# CLOUDFLARE_API_TOKEN=  # Token con DNS Read + Zone Read
# CLOUDFLARE_ZONE_ID=    # Opcional; si no se pone, se obtiene por nombre bodasdehoy.com

# Pruebas api-ia como usuario real (opcional; el front puede facilitar credenciales)
# Ver docs/PRUEBAS-COMO-USUARIO-REAL.md
# TEST_USER_EMAIL=       # Email usuario Firebase bodasdehoy (no subir a git)
# TEST_USER_PASSWORD=    # Contraseña (no subir a git)

# Endpoints canónicos (mínimo recomendado)
#
# API IA (chat/memories/tools)
# API_IA_URL=https://api3-ia.eventosorganizador.com
# NEXT_PUBLIC_API_IA_URL=https://api3-ia.eventosorganizador.com
#
# API MCP GraphQL (datos; antes API2)
# API_MCP_GRAPHQL_URL=https://api3-mcp-graphql.eventosorganizador.com/graphql
# NEXT_PUBLIC_API_MCP_GRAPHQL_URL=https://api3-mcp-graphql.eventosorganizador.com/graphql

# Imágenes/assets (temporalmente apiapp; en el futuro irá a un dominio dedicado)
# NEXT_PUBLIC_IMAGES_BASE_URL=https://apiapp.bodasdehoy.com
# (Legacy) NEXT_PUBLIC_BASE_URL=https://apiapp.bodasdehoy.com
#
# App principal (producción)
# NEXT_PUBLIC_EVENTSAPP=https://app.bodasdehoy.com

# Creador standalone (apps/creador-standalone) - URL de Copilot para el enlace "Abrir en Copilot"
# NEXT_PUBLIC_CHAT=https://chat.bodasdehoy.com
